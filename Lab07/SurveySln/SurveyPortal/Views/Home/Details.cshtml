@using SurveyPortal.Models.Survey.Survey
@model Survey

@{
    var sessionKey = $"draft_{Model.SurveyID}";
    var draftAnswer = Context.Session.GetString(sessionKey) ?? "";
}

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script>
        const textarea = document.getElementById("surveyAnswer");
        const surveyId = @Model.SurveyID;
        let timeout;

        if (textarea) {
            textarea.addEventListener("input", function () {
                clearTimeout(timeout);

                timeout = setTimeout(() => {
                    fetch(`/Home/SaveDraftAnswer?surveyId=${surveyId}`, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({ answer: textarea.value })
                    });
                }, 500);
            });
        }

        const answersList = document.getElementById("answersList");
        const answersSection = document.getElementById("answersSection");

        function appendAnswer(message) {
            if (!answersList) {
                return;
            }

            if (answersList.querySelector(`[data-answer-id="${message.surveyAnswerID}"]`)) {
                return;
            }

            const item = document.createElement("li");
            item.className = "list-group-item";
            item.dataset.answerId = message.surveyAnswerID;

            const answeredAt = new Date(message.answeredAt);
            const formattedDate = answeredAt.toLocaleString("uk-UA", {
                year: "numeric",
                month: "2-digit",
                day: "2-digit",
                hour: "2-digit",
                minute: "2-digit"
            });

            const dateEl = document.createElement("div");
            dateEl.className = "small text-muted";
            dateEl.textContent = formattedDate;

            const answerEl = document.createElement("div");
            answerEl.textContent = message.answer;

            item.appendChild(dateEl);
            item.appendChild(answerEl);

            answersList.prepend(item);

            if (answersSection) {
                answersSection.classList.remove("d-none");
            }
        }

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/surveyResults")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveAnswer", appendAnswer);

        connection.start()
            .then(() => connection.invoke("JoinSurvey", surveyId))
            .catch(err => console.error("SignalR connection error:", err));

        window.addEventListener("beforeunload", () => {
            if (connection.state === signalR.HubConnectionState.Connected) {
                connection.invoke("LeaveSurvey", surveyId);
            }
        });
    </script>
}

<div class="container mt-4">
    <h2>@Model.Title</h2>
    <p class="text-muted">@Model.Description</p>
    <p><strong>Survey Created By: </strong>@Model.Company?.Name</p>
    <p><strong>Created:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</p>
    <span class="badge bg-@(Model.IsActive ? "success" : "secondary")">
        @(Model.IsActive ? "Active" : "Over")
    </span>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success mt-3" role="alert">@TempData["Message"]</div>
    }

    @if (Model.IsActive)
    {
        <form asp-action="SaveSurveyAnswer" method="post" class="mt-4">
            <input type="hidden" name="SurveyID" value="@Model.SurveyID" />

            <div class="mb-3">
                <label for="surveyAnswer" class="form-label">Your Answer:</label>
                <textarea id="surveyAnswer" name="Answer" class="form-control" rows="6" placeholder="Type your answer here..." required>@draftAnswer</textarea>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                <button type="submit" class="btn btn-primary">Submit</button>
            </div>
        </form>
    }
    else
    {
        <p class="mt-3 text-muted">This survey is no longer accepting responses.</p>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    }

    <div id="answersSection" class="@(Model.SurveyAnswers.Any() ? "" : "d-none")">
        <hr />
        <h5 class="mt-4">Survey Results (live):</h5>
        <p class="text-muted small">New answers appear automatically for all users viewing this survey.</p>

        <div class="border rounded shadow-sm p-2" style="max-height: 300px; overflow-y: auto;">
            <ul id="answersList" class="list-group list-group-flush">
                @foreach (var answer in Model.SurveyAnswers.OrderByDescending(a => a.AnsweredAt))
                {
                    <li class="list-group-item" data-answer-id="@answer.SurveyAnswerID">
                        <div class="small text-muted">@answer.AnsweredAt.ToString("yyyy-MM-dd HH:mm")</div>
                        <div>@answer.Answer</div>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>
